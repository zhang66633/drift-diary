        {
          "segments": [
            {
              "text": "事情败露了。他盯着我，手已经从橹上收了回来，随时准备跳海游回去报信。这不是有准备的偷袭——被发现了，只能用最决绝的方式。",
              "condition": {"type": "flag", "target": "物资", "operator": "eq", "value": "全"}
            },
            {
              "text": "伊斯梅尔毫无防备地弯下腰。我知道，这是唯一的机会。",
              "condition": {"type": "flag", "target": "物资", "operator": "neq", "value": "全"}
            }
          ]
        }
      ],
      "choices": [
        {
          "id": "推_推",
          "text": "猛地抱住他的腿，把他掀翻下海",
