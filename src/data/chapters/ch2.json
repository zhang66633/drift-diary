            {"type": "resource", "target": "蜡", "value": 1, "operation": "add"},
            {"type": "resource", "target": "绳", "value": 1, "operation": "add"},
            {"type": "resource", "target": "工具", "value": 1, "operation": "add"},
            {"type": "resource", "target": "火药", "value": 2, "operation": "add"},
            {"type": "resource", "target": "弹药", "value": 2, "operation": "add"},
            {"type": "flag", "target": "物资", "value": "全"}
          ],
          "narration": {
            "text": "我搬了整整一夜：面包、大米、甜酒、蜂蜡、绳索、斧头、锯子、火药、猎枪、手枪……舢板塞得满满的，只够三个人坐——不对，明天只需要两个人的位置。",
            "trigger": "on_choice"
          },
          "nextScene": "ch2_5_推摩尔"
        },
        {
          "id": "逃_食",
